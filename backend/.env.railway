# ── Railway fornece automaticamente ──────────────────────────
# DATABASE_URL=<preenchida pelo Railway ao adicionar PostgreSQL>
# PORT=<preenchida pelo Railway>

# ── Obrigatório preencher ─────────────────────────────────────
NODE_ENV=production
JWT_SECRET=TROQUE_POR_UMA_SENHA_LONGA_ALEATORIA_32_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=TROQUE_POR_OUTRA_SENHA_LONGA_ALEATORIA
JWT_REFRESH_EXPIRES_IN=30d
APP_SECRET=TROQUE_POR_APP_SECRET

# ── Supabase (storage de vídeos/fotos) ───────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_KEY=sua_anon_key
SUPABASE_SERVICE_KEY=sua_service_role_key
SUPABASE_BUCKET_VIDEOS=gkhub-videos
SUPABASE_BUCKET_PHOTOS=gkhub-photos
SUPABASE_BUCKET_REPORTS=gkhub-reports

# ── CORS adicional (separado por vírgula) ─────────────────────
ALLOWED_ORIGINS=

# ── Push Notifications (Firebase Cloud Messaging) ────────────
# Cole o JSON inteiro da chave privada do service account do Firebase
# (Console → Configurações → Contas de serviço → Gerar nova chave privada),
# em UMA linha. Sem isto o push fica desativado (app continua funcionando).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# ── Opcionais ─────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...     (para análise IA de performance)
# SMTP_HOST=                (para notificações por email)
