# Application
NODE_ENV=development
PORT=3000
APP_SECRET=change_me_to_a_very_long_random_string

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gkhub
DB_USER=gkhub
DB_PASSWORD=gkhub_secret

# JWT
JWT_SECRET=change_me_jwt_secret_very_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_BUCKET_VIDEOS=gkhub-videos
SUPABASE_BUCKET_PHOTOS=gkhub-photos
SUPABASE_BUCKET_REPORTS=gkhub-reports

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Email (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@gkhub.app
SMTP_PASS=smtp_password

# AI (optional – OpenAI for enhanced analysis)
OPENAI_API_KEY=sk-...
